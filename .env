# ============== Default Model Settings ==============
# Default model to use (supports 100+ providers via LiteLLM)
# Examples:
#   - claude-sonnet-4-5-20250929 (Anthropic)
#   - openai/gpt-4o (OpenAI)
#   - azure/gpt-4 (Azure OpenAI)
#   - gemini-pro (Google)
#   - ollama/llama2 (Ollama local)
DEFAULT_MODEL=MiniMax-M2.5

# Model parameters
DEFAULT_TEMPERATURE=0.0
# DEFAULT_MAX_TOKENS=4096


# ============== LLM Provider API Keys ==============
# LiteLLM supports 100+ providers. Uncomment and set the keys you need:

# Anthropic (Claude models) - https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI models - https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Azure OpenAI - https://portal.azure.com/
# AZURE_API_KEY=your-azure-key
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2024-02-01

# Google (Gemini models) - https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=...

# Ollama (local models) - https://ollama.ai/
# OLLAMA_API_BASE=http://localhost:11434

# MiniMax (M2.5, M2.1) - https://platform.minimax.io
MINIMAX_API_KEY=sk-cp-ZVNwPbRA4EmhTNwSKqE3t30NGw5537tXYpshPkdc39nqJVm4IS7k2OUvzIDujufT_jIGTCHu2adxkBDgx5nu-SS66bI7Kfr0dRLlbhP_QYgtq0USVUgx3KQ
# OLLAMA_API_BASE=http://localhost:11434


# ============== Search Provider ==============
TAVILY_API_KEY=...
