# MinerBot 环境变量配置
# 复制此文件为 .env 并填入实际的API密钥

# ===== LLM Factory 模型配置 =====

# 默认模型 (格式: provider/model-name)
# 可选: minimax/MiniMax-M2.5, anthropic/claude-sonnet-4-6, openai/gpt-4o, google/gemini-2.0-flash
DEFAULT_MODEL=minimax/MiniMax-M2.5

# API Keys - 根据 DEFAULT_MODEL 配置对应的 key
MINIMAX_API_KEY=your_minimax_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# ===== 可选参数 =====

# 模型参数
TEMPERATURE=0.7
MAX_TOKENS=4096

# Tavily API Key (网络搜索)
TAVILY_API_KEY=your_tavily_api_key_here

# 数据库路径
SQLITE_DB_PATH=data/minerbot.db
